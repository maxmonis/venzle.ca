{
  "dependencies": {
    "htm-elements": "^0.1.9"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@vitest/coverage-v8": "^4.1.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.6.2",
    "prettier-plugin-organize-imports": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.3",
    "vite": "^7.1.2",
    "vite-plugin-package-version": "^1.1.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.0"
  },
  "name": "venzle.ca",
  "private": true,
  "scripts": {
    "build": "tsx build.ts && tsc && vite build --emptyOutDir",
    "bump": "npm version $(date '+%Y.%-m.%-d')",
    "dev": "tsx build.ts && vite --host",
    "lint": "prettier --write --ignore-path .gitignore .",
    "postinstall": "tsx build.ts",
    "prod": "npm run build && vite preview --host",
    "test": "tsx build.ts && vitest run --coverage"
  },
  "type": "module",
  "version": "2026.6.20"
}
